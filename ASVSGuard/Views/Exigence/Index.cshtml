@model ASVSGuard.Models.ExigenceFilterViewModel
@using ASVSGuard.Core.Entities
@{
    ViewData["Title"] = "ASVS Exigences";
}

<div class="page-hdr">
    <h1>ASVS Exigences <span style="font-size:1rem;font-weight:500;color:var(--text-muted)" id="ex-count">@Model.TotalCount</span></h1>
    <p>Browse all 286 OWASP ASVS 4.0 security requirements</p>
</div>

<!-- Sticky filter bar -->
<div class="filter-bar mb-4">
    <div class="d-flex flex-wrap gap-2 align-items-center">
        <!-- Search -->
        <div class="input-icon-wrap" style="flex:1;min-width:180px">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input type="text" id="ex-search" class="input-dark" placeholder="Search code or description…"
                   style="padding-left:36px;height:36px;font-size:.82rem" autocomplete="off" />
        </div>

        <!-- Level pills -->
        <div class="d-flex gap-1" id="level-pills">
            <button class="pill-btn active" data-level="">All levels</button>
            <button class="pill-btn" data-level="1">L1</button>
            <button class="pill-btn" data-level="2">L2</button>
            <button class="pill-btn" data-level="3">L3</button>
        </div>

        <!-- Category select -->
        <select id="ex-cat" class="input-dark" style="width:auto;min-width:150px;height:36px;font-size:.82rem;padding:0 10px">
            <option value="">All categories</option>
            @foreach (var cat in Model.Categories)
            {
                <option value="@cat.ToLower()">@cat</option>
            }
        </select>

        <!-- Status select -->
        <select id="ex-status" class="input-dark" style="width:auto;min-width:130px;height:36px;font-size:.82rem;padding:0 10px">
            <option value="">All statuses</option>
            @foreach (var s in Enum.GetValues<ExigenceStatus>())
            {
                <option value="@s.ToString().ToLower()">@s</option>
            }
        </select>

        <a asp-action="Import" class="btn-px btn-ghost" style="padding:7px 14px;font-size:.8rem;flex-shrink:0">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
            Import
        </a>
    </div>
</div>

<!-- Card grid -->
<div class="row g-3" id="exigence-grid">
    @foreach (var e in Model.Items)
    {
        <div class="col-12 col-sm-6 col-xl-4 exg-item"
             data-code="@e.Code.ToLower()"
             data-desc="@e.Description.ToLower()"
             data-level="@e.Level"
             data-cat="@e.Category.ToLower()"
             data-status="@e.Status.ToString().ToLower()">
            <a asp-action="Detail" asp-route-id="@e.Id" class="exigence-card">
                <div class="d-flex align-items-center justify-content-between gap-2">
                    <span class="badge-code">@e.Code</span>
                    <div class="d-flex gap-1">
                        @{
                            var lvlCls = e.Level switch { 1 => "badge-l1", 2 => "badge-l2", _ => "badge-l3" };
                            var lvlLbl = e.Level switch { 1 => "L1", 2 => "L2", _ => "L3" };
                        }
                        <span class="@lvlCls">@lvlLbl</span>
                        @{
                            var stCls = e.Status switch {
                                ExigenceStatus.Compliant      => "badge-compliant",
                                ExigenceStatus.Missing        => "badge-missing",
                                ExigenceStatus.Partial        => "badge-partial",
                                ExigenceStatus.NotApplicable  => "badge-na",
                                _                             => "badge-unknown"
                            };
                            var stLbl = e.Status switch {
                                ExigenceStatus.Compliant      => "✓",
                                ExigenceStatus.Missing        => "✗",
                                ExigenceStatus.Partial        => "~",
                                ExigenceStatus.NotApplicable  => "N/A",
                                _                             => "?"
                            };
                        }
                        <span class="badge-status @stCls">@stLbl</span>
                    </div>
                </div>
                <div class="ec-desc">@e.Description</div>
                <div style="margin-top:10px">
                    <span class="badge-cat" style="font-size:.68rem">@e.Category</span>
                </div>
            </a>
        </div>
    }
</div>

<!-- Empty state -->
<div id="ex-empty" class="d-none text-center py-5">
    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--text-muted)" stroke-width="1.5" style="margin-bottom:12px"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    <p style="color:var(--text-muted);font-size:.875rem">No exigences match your filters.</p>
    <button class="btn-px btn-ghost" style="font-size:.82rem;padding:7px 16px" onclick="resetFilters()">Clear filters</button>
</div>

@if (!Model.Items.Any())
{
    <div class="card-dark p-5 text-center">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--text-muted)" stroke-width="1.5" style="margin-bottom:14px"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
        <p style="color:var(--text-muted);font-size:.875rem;margin-bottom:16px">No exigences yet. Import the ASVS Excel file to get started.</p>
        <a asp-action="Import" class="btn-px btn-indigo" style="font-size:.85rem">Import Excel File</a>
    </div>
}

@section Scripts {
<script src="~/js/app.js" asp-append-version="true"></script>
<script>
window.resetFilters = function () {
    document.getElementById('ex-search').value = '';
    document.getElementById('ex-cat').value = '';
    document.getElementById('ex-status').value = '';
    document.querySelectorAll('#level-pills .pill-btn').forEach((b, i) => b.classList.toggle('active', i === 0));
    if (window.filterExigences) window.filterExigences();
};
</script>
}
