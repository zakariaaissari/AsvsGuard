@model ASVSGuard.Models.DashboardViewModel
@using ASVSGuard.Core.Entities
@{
    ViewData["Title"] = "Dashboard";
    int maxCat = Model.CategoryBreakdown.Any() ? Model.CategoryBreakdown.Max(c => c.Count) : 1;
}

<div class="page-hdr">
    <h1>Dashboard</h1>
    <p>OWASP ASVS 4.0 security compliance overview</p>
</div>

<!-- Stat cards -->
<div class="stat-grid mb-4">
    <div class="stat-card">
        <div class="d-flex justify-content-between align-items-start mb-2">
            <div class="stat-icon" style="background:rgba(99,102,241,.12)">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#6366f1" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
        </div>
        <div class="stat-number" style="color:#a5b4fc">@Model.TotalExigences</div>
        <div class="stat-label">Total Exigences</div>
    </div>
    <div class="stat-card">
        <div class="d-flex justify-content-between align-items-start mb-2">
            <div class="stat-icon" style="background:rgba(34,197,94,.1)">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
            </div>
        </div>
        <div class="stat-number" style="color:#86efac">@Model.Level1Count</div>
        <div class="stat-label">Level 1 (Minimum)</div>
    </div>
    <div class="stat-card">
        <div class="d-flex justify-content-between align-items-start mb-2">
            <div class="stat-icon" style="background:rgba(245,158,11,.1)">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            </div>
        </div>
        <div class="stat-number" style="color:#fcd34d">@Model.Level2Count</div>
        <div class="stat-label">Level 2 (Standard)</div>
    </div>
    <div class="stat-card">
        <div class="d-flex justify-content-between align-items-start mb-2">
            <div class="stat-icon" style="background:rgba(239,68,68,.1)">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            </div>
        </div>
        <div class="stat-number" style="color:#fca5a5">@Model.Level3Count</div>
        <div class="stat-label">Level 3 (Advanced)</div>
    </div>
</div>

<!-- Category chart + Quick actions -->
<div class="row g-3 mb-4">
    <div class="col-lg-7">
        <div class="card-dark p-4" style="height:100%">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div>
                    <div style="font-weight:600;font-size:.95rem">Category Breakdown</div>
                    <div style="font-size:.78rem;color:var(--text-muted)">Exigences per ASVS chapter</div>
                </div>
            </div>
            @if (Model.CategoryBreakdown.Any())
            {
                @foreach (var cat in Model.CategoryBreakdown)
                {
                    <div class="cat-bar">
                        <div class="cat-bar-meta">
                            <span>@cat.Category</span>
                            <span style="color:var(--primary)">@cat.Count</span>
                        </div>
                        <div class="cat-bar-track">
                            <div class="cat-bar-fill" style="width:@(cat.Count * 100 / maxCat)%"></div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div style="text-align:center;padding:40px;color:var(--text-muted)">
                    <div style="font-size:2rem;margin-bottom:8px">📋</div>
                    <p style="font-size:.875rem">No exigences yet.<br>Import the ASVS Excel file to get started.</p>
                    <a asp-controller="Exigence" asp-action="Import" class="btn-px btn-indigo" style="font-size:.82rem;padding:7px 16px">Import Excel</a>
                </div>
            }
        </div>
    </div>
    <div class="col-lg-5">
        <div class="card-dark p-4" style="height:100%">
            <div style="font-weight:600;font-size:.95rem;margin-bottom:4px">Quick Actions</div>
            <div style="font-size:.78rem;color:var(--text-muted);margin-bottom:20px">Get started in seconds</div>
            <div class="d-flex flex-column gap-3">
                <a asp-controller="Exigence" asp-action="Import" class="btn-px btn-indigo" style="width:100%;justify-content:flex-start;gap:10px">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                    Import Excel File
                </a>
                <a asp-controller="Repo" asp-action="Index" class="btn-px btn-ghost" style="width:100%;justify-content:flex-start;gap:10px">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                    Scan a Repository
                </a>
                <a asp-controller="Exigence" asp-action="Index" class="btn-px btn-ghost" style="width:100%;justify-content:flex-start;gap:10px">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
                    Browse Exigences
                </a>
            </div>
            <div style="margin-top:24px;padding-top:20px;border-top:1px solid var(--dark-border)">
                <div style="font-size:.75rem;color:var(--text-muted);margin-bottom:8px">ASVS Levels</div>
                <div class="d-flex gap-2 flex-wrap">
                    <span class="badge-l1">L1 Minimum</span>
                    <span class="badge-l2">L2 Standard</span>
                    <span class="badge-l3">L3 Advanced</span>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Recent scans -->
@if (Model.RecentScans.Any())
{
    <div class="card-dark p-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div>
                <div style="font-weight:600;font-size:.95rem">Recent Scans</div>
                <div style="font-size:.78rem;color:var(--text-muted)">Your latest repository analyses</div>
            </div>
            <a asp-controller="Repo" asp-action="Index" style="font-size:.8rem;color:var(--primary)">New scan →</a>
        </div>
        <table class="tbl">
            <thead>
                <tr>
                    <th>Repository</th>
                    <th>Date</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var scan in Model.RecentScans)
                {
                    <tr>
                        <td>
                            <div style="font-weight:500;color:var(--text-primary);font-size:.85rem">@scan.RepoName</div>
                            <div style="font-size:.75rem;color:var(--text-muted)">@scan.RepoUrl</div>
                        </td>
                        <td style="font-size:.8rem">@scan.ScannedAt.ToString("MMM d, yyyy")</td>
                        <td>
                            @{
                                var (cls, label) = scan.Status switch {
                                    RepoScanStatus.Done    => ("badge-done",    "Done"),
                                    RepoScanStatus.Running => ("badge-running", "Running"),
                                    RepoScanStatus.Failed  => ("badge-failed",  "Failed"),
                                    _                      => ("badge-unknown", "Pending")
                                };
                            }
                            <span class="@cls">@label</span>
                        </td>
                        <td>
                            <a asp-controller="Repo" asp-action="Result" asp-route-id="@scan.Id"
                               style="font-size:.8rem;color:var(--primary)">View →</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else if (User.Identity?.IsAuthenticated == true)
{
    <div class="card-dark p-4 text-center" style="padding:40px!important">
        <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="var(--text-muted)" stroke-width="1.5" style="margin-bottom:12px"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <p style="color:var(--text-muted);font-size:.875rem;margin:0 0 16px">No scans yet. Analyse your first repository.</p>
        <a asp-controller="Repo" asp-action="Index" class="btn-px btn-indigo">Scan a Repository</a>
    </div>
}
