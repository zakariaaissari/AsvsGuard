<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — ASVS Platform</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github-dark.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
@{
    var ctrl   = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var action = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    bool isAuth = User.Identity?.IsAuthenticated == true;
    string userName = User.Identity?.Name ?? "Guest";
    string userInitial = userName.Length > 0 ? userName[0].ToString().ToUpper() : "G";
}

<div class="app-shell">

    <!-- ── Sidebar ──────────────────────────────────── -->
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-logo">
            <div class="logo-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                </svg>
            </div>
            <div>
                <div class="logo-text">ASVS Platform</div>
                <div class="logo-sub" style="-webkit-text-fill-color:var(--text-muted)">Security Scanner</div>
            </div>
        </div>

        @if (isAuth)
        {
            <div class="sidebar-user">
                <div class="sidebar-avatar">@userInitial</div>
                <span class="sidebar-username">@userName</span>
            </div>
        }

        <nav class="sidebar-nav">
            <div class="nav-section">Main</div>
            <a class="nav-item @(ctrl == "Home" ? "active" : "")" asp-controller="Home" asp-action="Index">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                Dashboard
            </a>
            <a class="nav-item @(ctrl == "Exigence" ? "active" : "")" asp-controller="Exigence" asp-action="Index">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
                Exigences
            </a>
            <a class="nav-item @(ctrl == "Repo" ? "active" : "")" asp-controller="Repo" asp-action="Index">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                Repo Scanner
            </a>

            <div class="nav-section" style="margin-top:8px">AI Tools</div>
            <a class="nav-item" href="#" id="sidebar-chat-btn" onclick="window.openChatPanel?.(); return false;">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
                AI Chat
            </a>

            <div class="nav-section" style="margin-top:8px">Data</div>
            <a class="nav-item @(ctrl == "Exigence" && action == "Import" ? "active" : "")" asp-controller="Exigence" asp-action="Import">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                Import Excel
            </a>

            <div class="nav-section" style="margin-top:8px">Account</div>
            @if (isAuth)
            {
                <form asp-controller="Account" asp-action="Logout" method="post" style="margin:0">
                    <button type="submit" class="nav-item w-100 text-start" style="background:none;border:none;font-family:var(--font)">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                        Logout
                    </button>
                </form>
            }
            else
            {
                <a class="nav-item @(ctrl == "Account" && action == "Login" ? "active" : "")" asp-controller="Account" asp-action="Login">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h4a2 2 0 012 2v14a2 2 0 01-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
                    Login
                </a>
                <a class="nav-item @(ctrl == "Account" && action == "Register" ? "active" : "")" asp-controller="Account" asp-action="Register">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                    Register
                </a>
            }
        </nav>

        <div class="sidebar-footer">
            <span class="version-badge">ASVS 4.0 · 286 requirements</span>
        </div>
    </aside>

    <!-- ── Main area ─────────────────────────────────── -->
    <div class="main-area">

        <!-- Topbar -->
        <header class="topbar">
            <button class="topbar-icon-btn hamburger" id="hamburger">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
            </button>
            <span class="topbar-title">@(ViewData["Title"] ?? "Dashboard")</span>
            <div class="topbar-spacer"></div>
            <div class="topbar-search-wrap d-none d-md-block">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                <input type="text" class="topbar-search" placeholder="Search exigences…" id="topbar-search" autocomplete="off" />
            </div>
            <a class="topbar-icon-btn" asp-controller="Exigence" asp-action="Import" title="Import Excel">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
            </a>
            @if (isAuth)
            {
                <div class="topbar-user" id="topbar-user">
                    <div class="sidebar-avatar" style="width:28px;height:28px;font-size:.65rem">@userInitial</div>
                    <span class="d-none d-md-inline" style="font-size:.82rem;color:var(--text-secondary)">@userName</span>
                </div>
            }
            else
            {
                <a class="btn-px btn-indigo" style="padding:6px 14px;font-size:.8rem" asp-controller="Account" asp-action="Login">Sign In</a>
            }
        </header>

        <!-- Alerts -->
        @if (TempData["Success"] is string success)
        {
            <div style="margin:12px 30px 0;background:rgba(34,197,94,.12);border:1px solid rgba(34,197,94,.3);border-radius:var(--radius-sm);padding:10px 16px;color:#86efac;font-size:.875rem;display:flex;align-items:center;gap:8px">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                @success
            </div>
        }
        @if (TempData["Error"] is string error)
        {
            <div style="margin:12px 30px 0;background:rgba(239,68,68,.12);border:1px solid rgba(239,68,68,.3);border-radius:var(--radius-sm);padding:10px 16px;color:#fca5a5;font-size:.875rem;display:flex;align-items:center;gap:8px">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                @error
            </div>
        }

        <main class="main-content">
            @RenderBody()
        </main>
    </div><!-- end .main-area -->

    <!-- ── Chat panel — 3rd flex column ──────────────── -->
    @await Html.PartialAsync("_ChatWidget")

</div><!-- end .app-shell -->

<!-- ── Sidebar overlay (mobile) ─────────────────── -->
<div class="sidebar-overlay" id="sidebar-overlay"></div>

<!-- ── Chat overlay (tablet/mobile — behind chat drawer) ── -->
<div id="chat-overlay" onclick="window.closeChatPanel?.()"
     style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.55);backdrop-filter:blur(2px);z-index:205"></div>

<!-- ── Chat FAB (shown on tablet / mobile) ───────── -->
<button class="chat-fab" onclick="window.openChatPanel?.()" title="AI Assistant">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/>
    </svg>
    <span class="chat-online"></span>
</button>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>
<script src="~/js/chat.js" asp-append-version="true"></script>
<script src="~/js/app.js" asp-append-version="true"></script>
<script>
  document.getElementById('topbar-search')?.addEventListener('keydown', function(e) {
    if (e.key === 'Enter' && this.value.trim())
      window.location = '/Exigence?search=' + encodeURIComponent(this.value.trim());
  });
  document.addEventListener('DOMContentLoaded', () => hljs.highlightAll());
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
