@{
    ViewData["Title"] = "Sign In";
    Layout = "_AuthLayout";
}

<div class="auth-page">
    <!-- Left brand panel -->
    <div class="auth-left">
        <div>
            <div class="d-flex align-items-center gap-3 mb-5">
                <div class="logo-icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2">
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                    </svg>
                </div>
                <span style="font-size:1rem;font-weight:800;background:linear-gradient(135deg,#a5b4fc,#7dd3fc);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text">
                    ASVS Platform
                </span>
            </div>

            <h2 style="font-size:2.1rem;font-weight:800;color:#f1f5f9;line-height:1.25;margin-bottom:14px">
                Security compliance,<br/>simplified.
            </h2>
            <p style="font-size:.9rem;color:var(--text-secondary);line-height:1.75;margin-bottom:36px;max-width:360px">
                Scan GitHub repositories against 286 OWASP ASVS 4.0 requirements and get AI-powered security insights in seconds.
            </p>

            <div class="d-flex flex-column gap-3">
                <div class="d-flex align-items-center gap-3">
                    <div style="width:30px;height:30px;border-radius:8px;background:rgba(34,197,94,.15);display:flex;align-items:center;justify-content:center;flex-shrink:0">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2.5"><path d="M9 11l3 3L22 4"/></svg>
                    </div>
                    <span style="font-size:.855rem;color:var(--text-secondary)">Scan any public GitHub repository for free</span>
                </div>
                <div class="d-flex align-items-center gap-3">
                    <div style="width:30px;height:30px;border-radius:8px;background:rgba(99,102,241,.15);display:flex;align-items:center;justify-content:center;flex-shrink:0">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#a5b4fc" stroke-width="2.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                    </div>
                    <span style="font-size:.855rem;color:var(--text-secondary)">AI fix suggestions with exact file + line numbers</span>
                </div>
                <div class="d-flex align-items-center gap-3">
                    <div style="width:30px;height:30px;border-radius:8px;background:rgba(14,165,233,.15);display:flex;align-items:center;justify-content:center;flex-shrink:0">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#7dd3fc" stroke-width="2.5"><circle cx="12" cy="8" r="4"/><path d="M6 20v-2a6 6 0 0112 0v2"/></svg>
                    </div>
                    <span style="font-size:.855rem;color:var(--text-secondary)">Real-time AI security assistant chat</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Right form panel -->
    <div class="auth-right">
        <div class="auth-card">
            <h1 style="font-size:1.5rem;font-weight:700;margin-bottom:4px">Welcome back</h1>
            <p style="color:var(--text-muted);font-size:.875rem;margin-bottom:28px">Sign in to your account to continue</p>

            <div asp-validation-summary="All" style="background:rgba(239,68,68,.08);border:1px solid rgba(239,68,68,.25);color:#fca5a5;padding:10px 14px;border-radius:var(--radius-sm);margin-bottom:16px;font-size:.82rem;line-height:1.5"></div>

            <form method="post">
                <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />

                <div class="mb-3">
                    <label style="display:block;font-size:.8rem;font-weight:600;color:var(--text-secondary);margin-bottom:6px">
                        Email address
                    </label>
                    <input type="email" name="email" class="input-dark"
                           placeholder="you@company.com" required autocomplete="email" />
                </div>

                <div class="mb-4">
                    <label style="display:block;font-size:.8rem;font-weight:600;color:var(--text-secondary);margin-bottom:6px">
                        Password
                    </label>
                    <input type="password" name="password" class="input-dark"
                           placeholder="••••••••" required autocomplete="current-password" />
                </div>

                <button type="submit" class="btn-px btn-indigo" style="width:100%;justify-content:center;padding:11px;font-size:.9rem">
                    Sign in
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </button>
            </form>

            <p style="text-align:center;margin-top:22px;font-size:.855rem;color:var(--text-muted)">
                Don't have an account?
                <a asp-action="Register" style="color:var(--primary);font-weight:600">Create one free</a>
            </p>
        </div>
    </div>
</div>
