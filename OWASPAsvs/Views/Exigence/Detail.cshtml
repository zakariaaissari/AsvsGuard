@model OWASPAsvs.Models.ExigenceViewModel
@using OWASPAsvs.Core.Entities
@{
    ViewData["Title"] = $"ASVS {Model.Code}";
    var cweUrl = Model.CWE.HasValue ? $"https://cwe.mitre.org/data/definitions/{Model.CWE.Value}.html" : null;
}

<!-- Breadcrumb -->
<nav style="font-size:.8rem;color:var(--text-muted);margin-bottom:20px">
    <a asp-controller="Exigence" asp-action="Index" style="color:var(--text-muted)">Exigences</a>
    <span style="margin:0 8px">›</span>
    <span style="color:var(--text-primary)">@Model.Code</span>
</nav>

<div class="row g-4">

    <!-- Left column: info + compliance -->
    <div class="col-lg-5">

        <!-- Exigence info -->
        <div class="card-dark p-4 mb-3">
            <div class="d-flex align-items-center gap-2 mb-3">
                <span class="badge-code" style="font-size:.88rem">@Model.Code</span>
                @{
                    var lvlCls = Model.Level switch { 1 => "badge-l1", 2 => "badge-l2", _ => "badge-l3" };
                    var lvlLbl = Model.Level switch { 1 => "L1 Minimum", 2 => "L2 Standard", _ => "L3 Advanced" };
                }
                <span class="@lvlCls">@lvlLbl</span>
            </div>

            <p style="font-size:.9rem;color:var(--text-primary);line-height:1.7;margin-bottom:14px">@Model.Description</p>

            <div class="d-flex flex-wrap gap-2 mb-3">
                <span class="badge-cat">@Model.Category</span>
                @if (cweUrl != null)
                {
                    <a href="@cweUrl" target="_blank" rel="noopener"
                       style="background:rgba(14,165,233,.08);color:#7dd3fc;border:1px solid rgba(14,165,233,.2);border-radius:20px;font-size:.7rem;font-weight:600;padding:2px 9px;text-decoration:none">
                        CWE-@Model.CWE ↗
                    </a>
                }
            </div>

            <div style="font-size:.75rem;color:var(--text-muted)">
                Group: <span style="color:var(--text-secondary)">@Model.Group</span>
            </div>
        </div>

        <!-- Compliance status -->
        <div class="card-dark p-4">
            <div style="font-weight:600;font-size:.9rem;margin-bottom:16px">Compliance Status</div>
            <form asp-action="UpdateStatus" method="post">
                <input type="hidden" name="id" value="@Model.Id" />

                <div class="mb-3">
                    <label style="display:block;font-size:.8rem;font-weight:600;color:var(--text-secondary);margin-bottom:6px">Status</label>
                    <select name="status" class="input-dark">
                        @foreach (var s in Enum.GetValues<ExigenceStatus>())
                        {
                            <option value="@s" selected="@(Model.Status == s)">@s</option>
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label style="display:block;font-size:.8rem;font-weight:600;color:var(--text-secondary);margin-bottom:6px">Notes</label>
                    <textarea name="notes" class="input-dark" rows="3"
                              style="resize:vertical;min-height:70px">@Model.Notes</textarea>
                </div>

                <button type="submit" class="btn-px btn-indigo" style="width:100%;justify-content:center">
                    Save Status
                </button>
            </form>
        </div>
    </div>

    <!-- Right column: AI assistant -->
    <div class="col-lg-7">
        <div class="card-dark p-4">
            <div style="font-weight:600;font-size:.9rem;margin-bottom:4px">AI Security Assistant</div>
            <div style="font-size:.78rem;color:var(--text-muted);margin-bottom:20px">Powered by Llama 3.3 · DeepSeek V3 for code</div>

            <!-- Action buttons -->
            <div class="d-flex flex-wrap gap-2 mb-3">
                <button class="btn-px btn-indigo" id="btn-explain" data-id="@Model.Id" style="font-size:.82rem;padding:8px 16px">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                    Explain this requirement
                </button>
            </div>

            <!-- Code generation row -->
            <div style="border-top:1px solid var(--dark-border);padding-top:14px;margin-bottom:14px">
                <div style="font-size:.78rem;font-weight:600;color:var(--text-secondary);margin-bottom:10px">Generate compliant code example:</div>
                <div class="d-flex flex-wrap gap-2 mb-3" id="lang-pills">
                    @foreach (var lang in new[] { "csharp", "javascript", "java", "python", "go" })
                    {
                        var label = lang switch { "csharp" => "C#", "javascript" => "JS", "java" => "Java", "python" => "Python", "go" => "Go", _ => lang };
                        <button class="pill-btn @(lang == "csharp" ? "active" : "")" data-lang="@lang">@label</button>
                    }
                </div>
                <button class="btn-px btn-ghost" id="btn-code" data-id="@Model.Id" style="font-size:.82rem;padding:8px 16px">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
                    Generate code
                </button>
            </div>

            <!-- Result area -->
            <div id="ai-loading" class="d-none" style="padding:24px 0;text-align:center">
                <div style="display:inline-flex;align-items:center;gap:10px;color:var(--text-muted);font-size:.85rem">
                    <span style="width:16px;height:16px;border:2px solid var(--dark-border);border-top-color:var(--primary);border-radius:50%;display:inline-block;animation:spin .7s linear infinite"></span>
                    Generating response…
                </div>
            </div>

            <div id="ai-result" class="d-none">
                <!-- Header bar -->
                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px">
                    <span id="ai-result-label" style="font-size:.75rem;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:.06em"></span>
                    <button id="btn-copy" class="btn-px btn-ghost" style="font-size:.75rem;padding:4px 12px;gap:5px">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
                        Copy
                    </button>
                </div>
                <pre id="ai-content" style="background:#0d1117;border:1px solid var(--dark-border);border-radius:var(--radius-sm);padding:14px 16px;color:#e2e8f0;font-family:'JetBrains Mono','Fira Code',monospace;font-size:.82rem;line-height:1.65;overflow-x:auto;white-space:pre-wrap;word-break:break-word;margin:0"></pre>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="~/js/app.js" asp-append-version="true"></script>
<style>@@keyframes spin{to{transform:rotate(360deg)}}</style>
}
