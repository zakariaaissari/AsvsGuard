@{
    ViewData["Title"] = "Scan Repository";
}

<div class="page-hdr">
    <h1>Scan a Repository</h1>
    <p>Analyse any public GitHub repository against 286 OWASP ASVS 4.0 requirements</p>
</div>

<div class="row g-4">
    <!-- Scan form -->
    <div class="col-lg-7">
        <div class="card-dark p-4">
            <div asp-validation-summary="All" style="background:rgba(239,68,68,.08);border:1px solid rgba(239,68,68,.25);color:#fca5a5;padding:10px 14px;border-radius:var(--radius-sm);margin-bottom:16px;font-size:.82rem"></div>

            <form asp-action="Scan" method="post" id="scan-form">
                <div class="mb-4">
                    <label style="display:block;font-size:.82rem;font-weight:600;color:var(--text-secondary);margin-bottom:8px">
                        GitHub Repository URL
                    </label>
                    <div class="input-icon-wrap">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 00-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0020 4.77 5.07 5.07 0 0019.91 1S18.73.65 16 2.48a13.38 13.38 0 00-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 005 4.77a5.44 5.44 0 00-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 009 18.13V22"/></svg>
                        <input type="url" name="repoUrl" class="input-dark"
                               style="padding-left:36px"
                               placeholder="https://github.com/owner/repository" required />
                    </div>
                </div>

                <div class="mb-4">
                    <label style="display:block;font-size:.82rem;font-weight:600;color:var(--text-secondary);margin-bottom:4px">
                        GitHub Personal Access Token
                        <span style="color:var(--text-muted);font-weight:400;font-size:.75rem;margin-left:6px">optional</span>
                    </label>
                    <div style="font-size:.75rem;color:var(--text-muted);margin-bottom:8px">
                        Increases rate limit from 60 to 5,000 req/hour — required for private repos
                    </div>
                    <div class="input-icon-wrap">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
                        <input type="password" name="githubToken" class="input-dark"
                               style="padding-left:36px"
                               placeholder="ghp_… (leave blank for public repos)" autocomplete="off" />
                    </div>
                </div>

                <button type="submit" class="btn-px btn-indigo" id="scan-btn" style="width:100%;justify-content:center;padding:12px;font-size:.92rem">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                    Scan Repository
                </button>
            </form>

            <!-- Progress (hidden until submit) -->
            <div id="scan-progress" class="d-none" style="margin-top:24px;padding-top:20px;border-top:1px solid var(--dark-border)">
                <div style="font-size:.82rem;font-weight:600;color:var(--text-primary);margin-bottom:14px">Scanning in progress…</div>
                <div class="d-flex flex-column gap-0" id="scan-steps">
                    <div class="scan-step active" id="step-fetch">
                        <div class="step-icon active-icon">
                            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/></svg>
                        </div>
                        Fetching source files from GitHub
                    </div>
                    <div class="scan-step" id="step-ai">
                        <div class="step-icon wait-icon">
                            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/></svg>
                        </div>
                        Analysing against ASVS requirements (AI)
                    </div>
                    <div class="scan-step" id="step-save">
                        <div class="step-icon wait-icon">
                            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/></svg>
                        </div>
                        Saving findings to database
                    </div>
                </div>
                <div class="prog-track mt-3">
                    <div class="prog-fill prog-anim" style="width:100%"></div>
                </div>
                <p style="font-size:.75rem;color:var(--text-muted);margin-top:10px;text-align:center">
                    This may take 1–3 minutes depending on repository size
                </p>
            </div>
        </div>
    </div>

    <!-- How it works -->
    <div class="col-lg-5">
        <div class="card-dark p-4 mb-3">
            <div style="font-weight:600;font-size:.9rem;margin-bottom:16px">How the scanner works</div>
            <div class="d-flex flex-column gap-3">
                <div class="d-flex gap-3">
                    <div style="width:26px;height:26px;border-radius:50%;background:rgba(99,102,241,.15);color:#a5b4fc;font-size:.72rem;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px">1</div>
                    <div>
                        <div style="font-size:.855rem;font-weight:600;color:var(--text-primary);margin-bottom:2px">Fetch source files</div>
                        <div style="font-size:.78rem;color:var(--text-muted);line-height:1.5">Reads your actual code directly from GitHub — no cloning required</div>
                    </div>
                </div>
                <div class="d-flex gap-3">
                    <div style="width:26px;height:26px;border-radius:50%;background:rgba(99,102,241,.15);color:#a5b4fc;font-size:.72rem;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px">2</div>
                    <div>
                        <div style="font-size:.855rem;font-weight:600;color:var(--text-primary);margin-bottom:2px">AI code analysis</div>
                        <div style="font-size:.78rem;color:var(--text-muted);line-height:1.5">Checks each file line-by-line against all 286 ASVS requirements using Llama 3.3</div>
                    </div>
                </div>
                <div class="d-flex gap-3">
                    <div style="width:26px;height:26px;border-radius:50%;background:rgba(99,102,241,.15);color:#a5b4fc;font-size:.72rem;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px">3</div>
                    <div>
                        <div style="font-size:.855rem;font-weight:600;color:var(--text-primary);margin-bottom:2px">Detailed findings</div>
                        <div style="font-size:.78rem;color:var(--text-muted);line-height:1.5">Shows exact vulnerable lines with specific fix suggestions for your codebase</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card-dark p-4">
            <div style="font-weight:600;font-size:.9rem;margin-bottom:12px">Supported languages</div>
            <div class="d-flex flex-wrap gap-2 mb-4">
                @foreach (var lang in new[] { "C#", "JavaScript", "TypeScript", "Java", "Python", "Go", "PHP" })
                {
                    <span class="badge-cat">@lang</span>
                }
            </div>
            <div style="border-top:1px solid var(--dark-border);padding-top:14px;font-size:.78rem;color:var(--text-muted)">
                <div class="d-flex align-items-center gap-2 mb-1">
                    <span style="color:var(--success);font-weight:600">Public repos</span>
                    — no token needed
                </div>
                <div class="d-flex align-items-center gap-2">
                    <span style="color:var(--primary);font-weight:600">Private repos</span>
                    — requires a GitHub token with <code style="font-size:.72rem;color:#a5b4fc">repo</code> scope
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="~/js/app.js" asp-append-version="true"></script>
}
